# ============================================================
# HealthFit AI Chatbot — Environment Variables Template
# Copy this file to .env and update the values.
# The .env file is gitignored to protect secrets.
# ============================================================

# Flask secret key for session management (change in production)
SECRET_KEY=change-this-to-a-random-string

# Application environment: development | testing | production
FLASK_ENV=development

# NLP confidence threshold (0.0 to 1.0)
# Queries scoring below this are treated as fallback
CONFIDENCE_THRESHOLD=0.45

# Maximum number of messages returned in chat history
MAX_HISTORY_LENGTH=50
